{
  "verses": [
    {
      "id": 1,
      "verse_number": 1,
      "verse_key": "1:1",
      "hizb_number": 1,
      "rub_el_hizb_number": 1,
      "ruku_number": 1,
      "manzil_number": 1,
      "sajdah_number": null,
      "text_uthmani": "بِسْمِ ٱللَّهِ ٱلرَّحْمَـٰنِ ٱلرَّحِيمِ",
      "page_number": 1,
      "juz_number": 1,
      "translations": [
        {
          "id": 916430,
          "resource_id": 134,
          "text": "Dengan menyebut nama Allah Yang Maha Pemurah lagi Maha Penyayang<sup foot_note=209770>1</sup>."
        },
        {
          "id": 181444,
          "resource_id": 33,
          "text": "Dengan nama Allah Yang Maha Pengasih, Maha Penyayang."
        }
      ]
    },
    {
      "id": 2,
      "verse_number": 2,
      "verse_key": "1:2",
      "hizb_number": 1,
      "rub_el_hizb_number": 1,
      "ruku_number": 1,
      "manzil_number": 1,
      "sajdah_number": null,
      "text_uthmani": "ٱلْحَمْدُ لِلَّهِ رَبِّ ٱلْعَـٰلَمِينَ",
      "page_number": 1,
      "juz_number": 1,
      "translations": [
        {
          "id": 916431,
          "resource_id": 134,
          "text": "Segala puji<sup foot_note=682<sup foot_note=209772>2</sup>2>1</sup> bagi Allah, Tuhan3 semesta alam."
        },
        {
          "id": 177234,
          "resource_id": 33,
          "text": "Segala puji bagi Allah, Tuhan seluruh alam,"
        }
      ]
    },
    {
      "id": 3,
      "verse_number": 3,
      "verse_key": "1:3",
      "hizb_number": 1,
      "rub_el_hizb_number": 1,
      "ruku_number": 1,
      "manzil_number": 1,
      "sajdah_number": null,
      "text_uthmani": "ٱلرَّحْمَـٰنِ ٱلرَّحِيمِ",
      "page_number": 1,
      "juz_number": 1,
      "translations": [
        {
          "id": 916432,
          "resource_id": 134,
          "text": "Maha Pemurah lagi Maha Penyayang."
        },
        {
          "id": 177531,
          "resource_id": 33,
          "text": "Yang Maha Pengasih, Maha Penyayang,"
        }
      ]
    },
    {
      "id": 4,
      "verse_number": 4,
      "verse_key": "1:4",
      "hizb_number": 1,
      "rub_el_hizb_number": 1,
      "ruku_number": 1,
      "manzil_number": 1,
      "sajdah_number": null,
      "text_uthmani": "مَـٰلِكِ يَوْمِ ٱلدِّينِ",
      "page_number": 1,
      "juz_number": 1,
      "translations": [
        {
          "id": 916433,
          "resource_id": 134,
          "text": "Yang menguasai<sup foot_note=209773>1</sup> hari pembalasan<sup foot_note=209774>2</sup>."
        },
        {
          "id": 182987,
          "resource_id": 33,
          "text": "Pemilik hari pembalasan.<sup foot_note=134952>1</sup>"
        }
      ]
    },
    {
      "id": 5,
      "verse_number": 5,
      "verse_key": "1:5",
      "hizb_number": 1,
      "rub_el_hizb_number": 1,
      "ruku_number": 1,
      "manzil_number": 1,
      "sajdah_number": null,
      "text_uthmani": "إِيَّاكَ نَعْبُدُ وَإِيَّاكَ نَسْتَعِينُ",
      "page_number": 1,
      "juz_number": 1,
      "translations": [
        {
          "id": 916434,
          "resource_id": 134,
          "text": "Hanya kepada Engkau-lah kami menyembah<sup foot_note=209775>1</sup> dan hanya kepada Engkau-lah kami memohon pertolongan<sup foot_note=209776>2</sup>."
        },
        {
          "id": 182918,
          "resource_id": 33,
          "text": "Hanya kepada Engkaulah kami menyembah dan hanya kepada Engkaulah kami mohon pertolongan."
        }
      ]
    },
    {
      "id": 6,
      "verse_number": 6,
      "verse_key": "1:6",
      "hizb_number": 1,
      "rub_el_hizb_number": 1,
      "ruku_number": 1,
      "manzil_number": 1,
      "sajdah_number": null,
      "text_uthmani": "ٱهْدِنَا ٱلصِّرَٰطَ ٱلْمُسْتَقِيمَ",
      "page_number": 1,
      "juz_number": 1,
      "translations": [
        {
          "id": 916435,
          "resource_id": 134,
          "text": "Tunjukilah kami<sup foot_note=209777>1</sup> jalan yang lurus,"
        },
        {
          "id": 181877,
          "resource_id": 33,
          "text": "Tunjukilah kami jalan yang lurus,<sup foot_note=134953>1</sup>"
        }
      ]
    },
    {
      "id": 7,
      "verse_number": 7,
      "verse_key": "1:7",
      "hizb_number": 1,
      "rub_el_hizb_number": 1,
      "ruku_number": 1,
      "manzil_number": 1,
      "sajdah_number": null,
      "text_uthmani": "صِرَٰطَ ٱلَّذِينَ أَنْعَمْتَ عَلَيْهِمْ غَيْرِ ٱلْمَغْضُوبِ عَلَيْهِمْ وَلَا ٱلضَّآلِّينَ",
      "page_number": 1,
      "juz_number": 1,
      "translations": [
        {
          "id": 916436,
          "resource_id": 134,
          "text": "(yaitu) jalan orang-orang yang telah Engkau anugerahkan nikmat kepada mereka; bukan (jalan) mereka yang dimurkai dan bukan (pula jalan) mereka yang sesat<sup foot_note=209778>1</sup>."
        },
        {
          "id": 182567,
          "resource_id": 33,
          "text": "(yaitu) jalan orang-orang yang telah Engkau beri nikmat kepadanya; bukan (jalan) mereka yang dimurkai, dan bukan (pula jalan) mereka yang sesat.<sup foot_note=134954>1</sup>"
        }
      ]
    }
